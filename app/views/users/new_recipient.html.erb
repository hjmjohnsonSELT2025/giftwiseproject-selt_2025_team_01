<h1>New Recipient</h1>

<% if @recipient.errors.any? %>
  <div id="error_explanation">
    <h2><%= pluralize(@recipient.errors.count, "error") %> prohibited this recipient from being saved:</h2>
    <ul>
      <% @recipient.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @recipient, local: true do |f| %>
  <div class="field">
    <%= f.label :first_name, "First name" %><br>
    <%= f.text_field :first_name %>
  </div>

  <div class="field">
    <%= f.label :last_name, "Last name" %><br>
    <%= f.text_field :last_name %>
  </div>

  <div class="field">
    <%= f.label :age, "Age" %><br>
    <%= f.number_field :age %>
  </div>

  <div class="field">
    <%= f.label :occupation, "Occupation" %><br>
    <%= f.text_field :occupation %>
  </div>

  <div class="field">
    <%= f.label :hobbies, "Hobbies" %><br>
    <%= f.text_area :hobbies, rows: 3 %>
  </div>

  <div class="field">
    <%= f.label :likes, "Likes" %><br>
    <%= f.text_area :likes, rows: 3 %>
  </div>

  <div class="field">
    <%= f.label :dislikes, "Dislikes" %><br>
    <%= f.text_area :dislikes, rows: 3 %>
  </div>

  <div class="actions">
    <%= f.submit "Create Recipient" %>
  </div>
<% end %>
