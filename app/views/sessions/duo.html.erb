<h1>Duo Verification</h1>

<p>If Duo is configured correctly, you should see a Duo login prompt inside the box below.</p>

<div id="duo-target" style="width: 100%; max-width: 400px; height: 330px; border: 1px solid #ccc;"></div>

<hr>

<h2>Debug info (temporary)</h2>
<ul>
  <li>DUO_HOST: <code><%= DUO["DUO_HOST"].inspect %></code></li>
  <li>sig_request present?: <code><%= @sig_request.present? %></code></li>
  <li>sig_request prefix: <code><%= @sig_request[0, 10] if @sig_request %></code></li>
</ul>

<!-- Load Duo’s JS library -->
<script src="https://api.duosecurity.com/frame/hosted/Duo-Web-v2.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        console.log("Duo page loaded");
        console.log("window.Duo =", window.Duo);

        if (!window.Duo) {
            console.error("Duo JS library failed to load");
            return;
        }

        Duo.init({
            host: "<%= DUO["DUO_HOST"] %>",
            sig_request: "<%= @sig_request %>",
            post_action: "<%= duo_verify_url %>",
            post_argument: "sig_response"
        });
    });
</script>
